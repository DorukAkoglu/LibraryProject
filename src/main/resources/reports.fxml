<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>


<BorderPane prefHeight="600.0" prefWidth="900.0" stylesheets="@student.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studyLibrary.project.ReportStudentController">
   <left>
      <VBox alignment="TOP_CENTER" prefHeight="200.0" prefWidth="260.0" spacing="30.0" styleClass="sidemenu" stylesheets="@student.css" BorderPane.alignment="CENTER">
         <children>
            <ImageView fx:id="profilePicture" fitHeight="131.0" fitWidth="177.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@images/defaultProfilePicture.png" />
               </image>
            </ImageView>
            <Label fx:id="nameLabel" text="Name" textFill="#e9dfdf">
               <font>
                  <Font name="Calibri Light" size="18.0" />
               </font>
            </Label>
            <Label fx:id="departmentLabel" styleClass="accent-text" stylesheets="@student.css" text="Department" />
            <Button mnemonicParsing="false" onAction="#backToDashboard" styleClass="nav-button" stylesheets="@student.css" text="Return To Dashboard">
               <cursor>
                  <Cursor fx:constant="HAND" />
               </cursor>
            </Button>
         </children>
         <padding>
            <Insets top="30.0" />
         </padding>
      </VBox>
   </left>
   <center>
      <ScrollPane fitToWidth="true" hbarPolicy="NEVER" BorderPane.alignment="CENTER">
         <content>
            <VBox spacing="20.0">
               <children>
                  <HBox alignment="CENTER" maxHeight="-Infinity" maxWidth="1.7976931348623157E308" minHeight="100.0" minWidth="640.0" prefHeight="100.0" prefWidth="640.0" spacing="40.0">
                     <children>
                        <Button fx:id="viewAnnouncementsButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#showAnnouncements" prefHeight="150.0" prefWidth="250.0" styleClass="tab-active" stylesheets="@mybooks.css" text="View Announcements" />
                        <Button fx:id="composeReportButton" maxHeight="-Infinity" maxWidth="-Infinity" mnemonicParsing="false" onAction="#showComposeReport" prefHeight="150.0" prefWidth="250.0" style="-fx-border-radius: 5;" styleClass="tab-inactive" stylesheets="@mybooks.css" text="Compose Report" />
                     </children>
                     <padding>
                        <Insets top="30.0" />
                     </padding>
                  </HBox>
                  <StackPane prefWidth="200.0">
                     <children>
                        <VBox fx:id="announcementContainer" prefWidth="100.0" spacing="30.0" visible="false">
                           <padding>
                              <Insets left="50.0" right="50.0" />
                           </padding>
                        </VBox>
                        <VBox fx:id="composeReportContainer" prefWidth="640.0">
                           <padding>
                              <Insets left="50.0" right="50.0" />
                           </padding>
                           <children>
                              <ScrollPane fitToHeight="true" fitToWidth="true" maxHeight="1.7976931348623157E308" prefHeight="500.0" prefWidth="549.0" VBox.vgrow="ALWAYS">
                                 <content>
                                    <VBox fx:id="reportHistoryVBox" alignment="TOP_CENTER" prefWidth="100.0" />
                                 </content>
                              </ScrollPane>
                              <HBox fx:id="sendReportHBox" alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0" VBox.vgrow="NEVER">
                                 <children>
                                    <TextField fx:id="reportTextField" />
                                    <Button mnemonicParsing="false" onAction="#handleSentReport" text="Send" />
                                    <ComboBox fx:id="librarianComboBox" prefHeight="16.0" prefWidth="137.0" promptText="Select librarian" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </StackPane>
               </children>
               <padding>
                  <Insets bottom="50.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>
   </center>
</BorderPane>
