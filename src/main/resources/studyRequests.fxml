<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane minHeight="600.0" minWidth="900.0" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: #12121f;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studyLibrary.project.StudyRequestController">
    <VBox prefHeight="81.0" prefWidth="900.0" styleClass="header-pane" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
      <children>
      
          <Label alignment="CENTER" maxWidth="Infinity" prefHeight="22.0" prefWidth="860.0" styleClass="header-title" text="Study Requests">
              <font>
               <Font size="22.0" />
            </font>
          </Label>
      </children></VBox>
    <TabPane fx:id="tabPane" styleClass="requests-tab-pane" tabClosingPolicy="UNAVAILABLE" AnchorPane.bottomAnchor="80.0" AnchorPane.leftAnchor="150.0" AnchorPane.rightAnchor="150.0" AnchorPane.topAnchor="110.0">
        <Tab>
            <graphic>
                <HBox alignment="CENTER" spacing="6">
                    <Label text="📨 Incoming Requests" />
                </HBox>
            </graphic>
            <content>
                <ScrollPane fx:id="myScrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #12121f; -fx-background: #12121f;">
                    <content>
                        <VBox fx:id="requestsBox" spacing="10" style="-fx-padding: 15;" />
                    </content>
                </ScrollPane>
            </content>
        </Tab>

        <Tab>
            <graphic>
                <HBox alignment="CENTER" spacing="6">
                    <Label text="📤 Sent Requests" />
                </HBox>
            </graphic>
            <content>
                <ScrollPane fx:id="sentScrollPane" fitToWidth="true" hbarPolicy="NEVER" style="-fx-background-color: #12121f;                                    -fx-background: #12121f;">
                    <content>
                        <VBox fx:id="sentRequestsBox" spacing="10" style="-fx-padding: 15;" />
                    </content>
                </ScrollPane>
            </content>
        </Tab>

    </TabPane>
    <Button fx:id="returnButton" maxWidth="200.0" onAction="#backToStudyMateMenu" style="-fx-translate-x: 0;" styleClass="return-button" text="← Go Back" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" />

</AnchorPane>
