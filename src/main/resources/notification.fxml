<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="600" prefWidth="900" style="-fx-background-color: #12121f;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studyLibrary.project.NotificationController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: #1e1e2e; -fx-border-color: #2d2d3d; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets bottom="15" left="20" right="20" top="15" />
            </padding>

            <Button onAction="#backToDashboard" style="-fx-background-color: #2d2d3d; -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 14;" text="← Back" />

            <Label style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;" text="Notifications" HBox.hgrow="ALWAYS" />

            <Button onAction="#markAllAsRead" style="-fx-background-color: #2d2d3d; -fx-text-fill: #aaa; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 14;" text="Mark All as Read" />

            <Button onAction="#clearAll" style="-fx-background-color: #5c2d2d; -fx-text-fill: #ff6b6b; -fx-background-radius: 8; -fx-cursor: hand; -fx-padding: 7 14;" text="Clear all" />
        </HBox>
    </top>
    <left>
        <VBox prefWidth="190" spacing="8" style="-fx-background-color: #1e1e2e; -fx-border-color: #2d2d3d; -fx-border-width: 0 1 0 0;">
            <padding>
                <Insets bottom="20" left="12" right="12" top="20" />
            </padding>

            <Label style="-fx-text-fill: #666; -fx-font-size: 10px; -fx-font-weight: bold;" text="Filter" />

            <Button fx:id="filterAllButton" maxWidth="Infinity" onAction="#filterAll" style="-fx-background-color: #3d3d5c; -fx-text-fill: white; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: bold;" text="🔔  All Notifications" />

            <Button fx:id="filterUnreadButton" maxWidth="Infinity" onAction="#filterUnread" style="-fx-background-color: transparent; -fx-text-fill: #ccc; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;" text="🔵  Unread" />

            <Separator style="-fx-background-color: #2d2d3d;" />

            <Label style="-fx-text-fill: #666; -fx-font-size: 10px; -fx-font-weight: bold;" text="Category" />

            <Button fx:id="filterBooksButton" maxWidth="Infinity" onAction="#filterBooks" style="-fx-background-color: transparent; -fx-text-fill: #ccc; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;" text="📚  Books" />

            <Button fx:id="filterStudyButton" maxWidth="Infinity" onAction="#filterStudy" style="-fx-background-color: transparent; -fx-text-fill: #ccc; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;" text="🤝  StudyMate" />

            <Button fx:id="filterTableButton" maxWidth="Infinity" onAction="#filterTable" style="-fx-background-color: transparent; -fx-text-fill: #ccc; -fx-alignment: CENTER_LEFT; -fx-padding: 8 12; -fx-background-radius: 8; -fx-cursor: hand;" text="🪑  Table" />
            <Separator style="-fx-background-color: #2d2d3d;" />
            <VBox alignment="CENTER" spacing="5" style="-fx-background-color: #2d2d3d; -fx-background-radius: 10; -fx-padding: 12;">
                <Label style="-fx-text-fill: #888; -fx-font-size: 11px;" text="Unread" />
                <Label fx:id="unreadCountLabel" style="-fx-text-fill: #4a90d9; -fx-font-size: 30px; -fx-font-weight: bold;" text="0" />
            </VBox>

        </VBox>
    </left>
    <center>
        <StackPane>
            <VBox fx:id="emptyStateBox" alignment="CENTER" managed="false" spacing="12" visible="false">
                <Label style="-fx-font-size: 48px;" text="🔔" />
                <Label fx:id="emptyTitleLabel" style="-fx-text-fill: #555; -fx-font-size: 16px; -fx-font-weight: bold;" text="No notifications yet" />
                <Label fx:id="emptySubtitleLabel" style="-fx-text-fill: #444; -fx-font-size: 12px;" text="When you borrow a book or have a study request, it will appear here." textAlignment="CENTER" wrapText="true" />
            </VBox>
            <ListView fx:id="notificationListView" style="-fx-background-color: #12121f; -fx-border-color: transparent;" />
        </StackPane>
    </center>

</BorderPane>
