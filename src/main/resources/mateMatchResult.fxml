<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" styleClass="root-bg" stylesheets="@studymate.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studyLibrary.project.StudyMateSessionController">
   <children>
      <BorderPane prefHeight="605.0" prefWidth="885.0">
         <top>
            <HBox alignment="CENTER" prefWidth="200.0" BorderPane.alignment="CENTER">
               <children>
                  <Region prefHeight="54.0" prefWidth="91.0" HBox.hgrow="ALWAYS" />
                  <Label alignment="CENTER" prefHeight="54.0" prefWidth="375.0" text="Find a StudyMate" textFill="WHITE" HBox.hgrow="ALWAYS">
                     <font>
                        <Font name="Dubai Medium" size="30.0" />
                     </font>
                  </Label>
                  <Region prefHeight="54.0" prefWidth="91.0" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </top>
         <bottom>
            <HBox alignment="CENTER" minHeight="-Infinity" minWidth="-Infinity" prefWidth="840.0" BorderPane.alignment="CENTER">
               <children>
                  <Button alignment="CENTER" mnemonicParsing="false" onAction="#endSession" prefHeight="50.0" prefWidth="229.0" style="-fx-background-radius: 20; -fx-background-color: red;" text="End Session" textFill="WHITE" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Button>
                  <Region prefHeight="100.0" prefWidth="38.0" />
                  <Button alignment="CENTER" layoutX="297.0" layoutY="35.0" mnemonicParsing="false" onAction="#goNext" prefHeight="50.0" prefWidth="229.0" style="-fx-background-radius: 20; -fx-background-color: orange;" text="Next" textFill="WHITE">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Button>
                  <Region layoutX="411.0" layoutY="10.0" prefHeight="100.0" prefWidth="38.0" />
                  <Button alignment="CENTER" layoutX="430.0" layoutY="35.0" mnemonicParsing="false" prefHeight="50.0" prefWidth="229.0" style="-fx-background-radius: 20; -fx-background-color: lime;" text="Add" textFill="WHITE">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Button>
               </children>
            </HBox>
         </bottom>
         <center>
            <HBox alignment="CENTER" spacing="30.0" BorderPane.alignment="CENTER">
               <BorderPane.margin>
                  <Insets />
               </BorderPane.margin>
               <children>
                  <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="400.0" prefWidth="400.0" styleClass="profile-card" stylesheets="@studymate.css">
                     <children>
                        <ImageView fitHeight="98.0" fitWidth="103.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/defaultProfilePicture.png" />
                           </image>
                        </ImageView>
                        <Label fx:id="nameLabel" alignment="CENTER" prefHeight="36.0" prefWidth="355.0" text="Name" textFill="WHITE">
                           <font>
                              <Font size="25.0" />
                           </font>
                        </Label>
                        <Label fx:id="ageLabel" alignment="CENTER" prefHeight="36.0" prefWidth="471.0" text="Age" textFill="WHITE">
                           <font>
                              <Font size="25.0" />
                           </font>
                        </Label>
                        <Label fx:id="departmentLabel" alignment="CENTER" prefHeight="36.0" prefWidth="514.0" text="Department" textFill="WHITE">
                           <font>
                              <Font size="25.0" />
                           </font>
                        </Label>
                        <Label fx:id="courseLabel" alignment="CENTER" prefHeight="36.0" prefWidth="483.0" text="Course" textFill="WHITE">
                           <font>
                              <Font size="25.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" layoutX="10.0" layoutY="10.0" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="400.0" prefWidth="400.0" styleClass="profile-card" stylesheets="@studymate.css">
                     <children>
                        <ImageView fitHeight="98.0" fitWidth="103.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@images/defaultProfilePicture.png" />
                           </image>
                        </ImageView>
                        <Label fx:id="matchedNameLabel" alignment="CENTER" prefHeight="36.0" prefWidth="355.0" text="Name" textFill="WHITE">
                           <font>
                              <Font size="25.0" />
                           </font>
                        </Label>
                        <Label fx:id="matchedAgeLabel" alignment="CENTER" prefHeight="36.0" prefWidth="471.0" text="Age" textFill="WHITE">
                           <font>
                              <Font size="25.0" />
                           </font>
                        </Label>
                        <Label fx:id="matchedDepartmentLabel" alignment="CENTER" prefHeight="36.0" prefWidth="514.0" text="Department" textFill="WHITE">
                           <font>
                              <Font size="25.0" />
                           </font>
                        </Label>
                        <Label fx:id="matchedCourseLabel" alignment="CENTER" prefHeight="36.0" prefWidth="483.0" text="Course" textFill="WHITE">
                           <font>
                              <Font size="25.0" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </center>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <StackPane.margin>
            <Insets bottom="50.0" />
         </StackPane.margin>
      </BorderPane>
   </children>
</StackPane>
