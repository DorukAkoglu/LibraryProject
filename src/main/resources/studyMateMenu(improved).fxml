<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane styleClass="root-bg" stylesheets="@studymate.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studyLibrary.project.StudyMateController">
   <children>
      <BorderPane>
         <top>
            <HBox alignment="CENTER" prefWidth="200.0" BorderPane.alignment="CENTER">
               <children>
                  <Button alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#switchToStudentDashboard" prefHeight="39.0" prefWidth="75.0" style="-fx-background-color: transparent; -fx-text-fill: rgba(255, 255, 255, 0.7); -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-radius: 10;" text="Back" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                     <font>
                        <Font name="Dubai Medium" size="15.0" />
                     </font>
                     <cursor>
                        <Cursor fx:constant="HAND" />
                     </cursor>
                  </Button>
                  <Region prefHeight="0.0" prefWidth="0.0" HBox.hgrow="ALWAYS" />
                  <Label alignment="CENTER" prefHeight="54.0" prefWidth="375.0" text="Find a StudyMate" textFill="WHITE" HBox.hgrow="ALWAYS">
                     <font>
                        <Font name="Dubai Medium" size="30.0" />
                     </font>
                  </Label>
                  <Region prefHeight="54.0" prefWidth="91.0" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </top>
         <bottom>
            <HBox alignment="CENTER" minHeight="-Infinity" minWidth="-Infinity" prefWidth="840.0" BorderPane.alignment="CENTER">
               <children>
                  <Button alignment="CENTER" mnemonicParsing="false" onAction="#displayRequests" prefHeight="50.0" prefWidth="229.0" style="-fx-background-radius: 20; -fx-background-color: rgba(30, 41, 59, 0.9);" text="View Study Requests" textFill="WHITE" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets />
                     </HBox.margin>
                     <font>
                        <Font size="20.0" />
                     </font>
                  </Button>
                  <Region prefHeight="100.0" prefWidth="38.0" />
                  <ComboBox fx:id="courseComboBox" onAction="#setCourse" prefHeight="50.0" prefWidth="200.0" promptText="Select Course" style="-fx-background-color: rgba(255,255,255,0.2); -fx-background-radius: 20;" HBox.hgrow="ALWAYS" />
               </children>
            </HBox>
         </bottom>
         <center>
            <VBox alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="500.0" minWidth="400.0" styleClass="profile-card" stylesheets="@studymate.css" BorderPane.alignment="CENTER">
               <children>
                  <ImageView fitHeight="98.0" fitWidth="103.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@images/defaultProfilePicture.png" />
                     </image>
                  </ImageView>
                  <Label fx:id="nameLabel" alignment="CENTER" maxWidth="-Infinity" text="Name" textFill="WHITE">
                     <font>
                        <Font size="25.0" />
                     </font>
                  </Label>
                  <Label fx:id="ageLabel" alignment="CENTER" maxWidth="-Infinity" text="Age" textFill="WHITE">
                     <font>
                        <Font size="25.0" />
                     </font>
                  </Label>
                  <Label fx:id="departmentLabel" alignment="CENTER" maxWidth="-Infinity" text="Department" textFill="WHITE">
                     <font>
                        <Font size="25.0" />
                     </font>
                  </Label>
                  <Label fx:id="courseLabel" alignment="CENTER" maxWidth="-Infinity" text="Course" textFill="WHITE">
                     <font>
                        <Font size="25.0" />
                     </font>
                  </Label>
                  <Button alignment="CENTER" maxWidth="-Infinity" mnemonicParsing="false" onAction="#handleFindMatchButton" styleClass="find-btn" stylesheets="@studymate.css" text="Find StudyMate">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </Button>
                  <Label fx:id="errorMessage" style="-fx-text-fill: red;" text="No Study Mates Are Available Within Your Preferences" />
               </children>
               <BorderPane.margin>
                  <Insets />
               </BorderPane.margin>
            </VBox>
         </center>
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <StackPane.margin>
            <Insets bottom="50.0" />
         </StackPane.margin>
      </BorderPane>
   </children>
</StackPane>
