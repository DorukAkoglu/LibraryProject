<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane minHeight="600.0" minWidth="900.0" prefHeight="600.0" prefWidth="900.0" styleClass="root" stylesheets="@book.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studyLibrary.project.BookController">
    
    <padding>
        <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
    </padding>

    <top>
        <VBox spacing="20.0" styleClass="header-box" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="20.0" />
            </BorderPane.margin>
            
            <VBox fx:id="notificationBox" alignment="TOP_CENTER" mouseTransparent="true" />
            
            <Label styleClass="header-title" text="Library Book Search" />
            
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <TextField fx:id="searchField" promptText="Search book by title..." styleClass="search-field" HBox.hgrow="ALWAYS" />
                
                <ComboBox fx:id="categoryFilter" prefWidth="150.0" promptText="Category" styleClass="filter-combo" />
                
                <CheckBox fx:id="availabilityFilter" styleClass="filter-checkbox" text="Available Only" />
                
                <Button mnemonicParsing="false" onAction="#handleSearchAction" styleClass="search-button" text="Search" />
            </HBox>
        </VBox>
    </top>

    <center>
        <ListView fx:id="bookListView" prefHeight="200.0" prefWidth="200.0" styleClass="book-list-view" BorderPane.alignment="CENTER">
            <BorderPane.margin>
                <Insets bottom="20.0" />
            </BorderPane.margin>
        </ListView>
    </center>

    <bottom>
        <HBox alignment="CENTER" BorderPane.alignment="CENTER">
            <Button mnemonicParsing="false" onAction="#goBackToDashboard" styleClass="back-button" text="🔙 Back to Dashboard" />
        </HBox>
    </bottom>

</BorderPane>
