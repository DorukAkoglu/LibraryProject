<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane minHeight="600.0" minWidth="900.0" prefHeight="600.0" prefWidth="900.0" style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #4c1d95);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="studyLibrary.project.BookController">
   
   <padding>
      <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
   </padding>

   <top>
      <VBox spacing="20.0" style="-fx-background-color: rgba(255, 255, 255, 0.05); -fx-background-radius: 20; -fx-border-color: rgba(255, 255, 255, 0.1); -fx-border-width: 1.5; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.3), 15, 0, 0, 8);" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="20.0" />
         </BorderPane.margin>
         
         <Label text="Library Book Search" textFill="WHITE">
            <font>
               <Font name="System Bold Italic" size="24.0" />
            </font>
         </Label>
         
         <HBox alignment="CENTER_LEFT" spacing="20.0">
            <TextField fx:id="searchField" promptText="Search book by title..." style="-fx-background-color: #2c3e50; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 8 15;" HBox.hgrow="ALWAYS" />
            
            <ComboBox fx:id="categoryFilter" prefWidth="150.0" promptText="Category" style="-fx-background-color: #456585; -fx-mark-color: white;" />
            <ComboBox fx:id="pagesFilter" prefWidth="120.0" promptText="Pages" style="-fx-background-color: #456585; -fx-mark-color: white;" />
            
            <CheckBox fx:id="availabilityFilter" text="Available Only" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="13.0" />
               </font>
            </CheckBox>
            
            <Button mnemonicParsing="false" onAction="#handleSearchAction" style="-fx-background-color: transparent; -fx-text-fill: #f39c12; -fx-border-color: #f39c12; -fx-border-width: 1.5; -fx-border-radius: 20; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 8 20;" text="Search" />
         </HBox>
      </VBox>
   </top>

   <center>
      <ListView fx:id="bookListView" prefHeight="200.0" prefWidth="200.0" style="-fx-background-color: rgba(30, 39, 46, 0.6); -fx-background-radius: 10; -fx-border-color: #34495e; -fx-border-radius: 10; -fx-control-inner-background: transparent;" BorderPane.alignment="CENTER">
         <BorderPane.margin>
            <Insets bottom="20.0" />
         </BorderPane.margin>
      </ListView>
   </center>

   <bottom>
      <HBox alignment="CENTER" BorderPane.alignment="CENTER">
         
         <Button mnemonicParsing="false" onAction="#goBackToDashboard" style="-fx-background-color: transparent; -fx-text-fill: rgba(255, 255, 255, 0.7); -fx-font-size: 15px; -fx-cursor: hand; -fx-border-color: rgba(255, 255, 255, 0.3); -fx-border-radius: 10; -fx-padding: 8 15;" text="🔙 Back to Dashboard" />
         
         <Region HBox.hgrow="ALWAYS" />
         
         <Button fx:id="borrowButton" mnemonicParsing="false" onAction="#handleBorrowAction" style="-fx-background-color: transparent; -fx-text-fill: #f39c12; -fx-border-color: #f39c12; -fx-border-width: 1.5; -fx-border-radius: 20; -fx-font-weight: bold; -fx-cursor: hand; -fx-padding: 10 20;" text="Borrow Selected Book" />
      </HBox>
   </bottom>

</BorderPane>